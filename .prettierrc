{
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "bracketSameLine": false,
  "overrides": [
    {
      "files": "**/routeTree.gen.ts",
      "options": { "printWidth": 80 }
    }
  ]
}
